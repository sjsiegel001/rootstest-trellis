# Local .terraform directories
.terraform/
.terraform.tfstate.lock.info

# State files — never commit (may contain secrets/IPs; use remote state for teams)
*.tfstate
*.tfstate.*

# Plan output
*.tfplan

# Crash logs
crash.log
crash.*.log

# Override files (local-only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Note: .terraform.lock.hcl IS committed intentionally (provider version pinning)
